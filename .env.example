# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=slotsync
POSTGRES_USER=slotsync
POSTGRES_PASSWORD=slotsync_secret

# ─── App ─────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_very_long_random_string_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
APP_BASE_URL=http://localhost:8010

# ─── E-mail (SMTP) ───────────────────────────────────────────
# Defina MAIL_ENABLED=true para ativar o envio de e-mails
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASSWORD=sua_senha_de_app
EMAILS_FROM_NAME=SlotSync
EMAILS_FROM_EMAIL=noreply@slotsync.app
